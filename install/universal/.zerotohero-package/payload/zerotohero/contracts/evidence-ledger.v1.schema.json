        "next_action": { "$ref": "#/$defs/nonPlaceholderString" },
        "next_verification": { "$ref": "#/$defs/nonPlaceholderString" },
        "stop_condition": { "$ref": "#/$defs/nonPlaceholderString" },
        "updated_at": { "type": "string", "format": "date-time" },
        "supersedes": { "type": ["string", "null"] },
        "rehydration": {
          "type": ["object", "null"],
